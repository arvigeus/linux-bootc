#!/usr/bin/env bash
# appiget - minimal AppImage manager
# Installs, updates, removes, and lists AppImages from GitHub releases
# Updates use delta patching (appimageupdatetool if available) with GitHub fallback

set -euo pipefail

# Constants
readonly STATE_DIR=/etc/appiget/state.d
readonly DESKTOP_DIR=/usr/share/applications
readonly ICON_DIR=/usr/share/icons/hicolor
readonly GITHUB_API=https://api.github.com/repos
readonly BIN_DIR=/usr/local/bin

# Flags
NONINTERACTIVE=false

# Color output
readonly RED='\033[0;31m'
readonly GREEN='\033[0;32m'
readonly YELLOW='\033[1;33m'
readonly NC='\033[0m' # No Color

# ============================================================================
# Utility functions
# ============================================================================

die() {
	echo -e "${RED}error: $*${NC}" >&2
	exit 1
}

warn() {
	echo -e "${YELLOW}warning: $*${NC}" >&2
}

info() {
	if [[ "$NONINTERACTIVE" != true ]]; then
		echo -e "${GREEN}→${NC} $*"
	fi
}

# Extract app-id from filename by stripping version, arch, and .AppImage suffix
_app_id() {
	local filename=$1
	# Strip .AppImage, then architecture, then version patterns (e.g., -1.2.3, _v2.0, -2022.1.0)
	sed -E 's/\.AppImage$//i; s/[-_](x86_64|aarch64|armv7l|i686)(-|$)//i; s/[-_]([vV]?[0-9]+[._-][0-9]+.*)$//' <<<"$filename" | tr '[:upper:]' '[:lower:]'
}

# Read value from state JSON
_read_state() {
	local app_id=$1
	local key=$2
	local state_file="$STATE_DIR/${app_id}.json"
	[[ -f "$state_file" ]] || return 1
	jq -r ".${key}" "$state_file" 2>/dev/null || return 1
}

# Write state JSON with repo, pattern, version
_write_state() {
	local app_id=$1
	local repo=$2
	local pattern=$3
	local version=$4
	local state_file="$STATE_DIR/${app_id}.json"

	mkdir -p "$STATE_DIR"
	jq -n \
		--arg repo "$repo" \
		--arg pattern "$pattern" \
		--arg version "$version" \
		'{repo: $repo, pattern: $pattern, version: $version}' >"$state_file"
}

# Query GitHub API for latest release assets
# Returns JSON array of assets
_github_assets() {
	local owner_repo=$1
	local url="${GITHUB_API}/${owner_repo}/releases/latest"

	curl -s -f "$url" | jq -r '.assets[] | .name' 2>/dev/null || return 1
}

# Find best AppImage asset for current architecture
# Prefers matching uname -m, falls back to any .AppImage
_github_latest() {
	local owner_repo=$1
	local pattern=$2
	local arch
	arch=$(uname -m)

	local assets
	assets=$(_github_assets "$owner_repo") || die "Failed to fetch releases for $owner_repo"

	# Filter by pattern and architecture preference
	local best
	best=$(echo "$assets" | grep -E "\.AppImage$" | grep "$pattern" | grep "$arch" | head -1)

	if [[ -z "$best" ]]; then
		# Fallback: any .AppImage matching pattern
		best=$(echo "$assets" | grep -E "\.AppImage$" | grep "$pattern" | head -1)
	fi

	[[ -n "$best" ]] || die "No AppImage found matching pattern: $pattern"
	echo "$best"
}

# Get download URL for asset from GitHub release
_github_download_url() {
	local owner_repo=$1
	local asset_name=$2
	local url="${GITHUB_API}/${owner_repo}/releases/latest"

	curl -s -f "$url" | jq -r ".assets[] | select(.name == \"$asset_name\") | .browser_download_url" || die "Failed to get download URL"
}

# Extract owner/repo from GitHub URL
_parse_github_url() {
	local url=$1
	echo "$url" | sed -E 's|https?://github\.com/||; s/\.git$//'
}

# ============================================================================
# Command: install
# ============================================================================

cmd_install() {
	local url="${1:-}"
	[[ -n "$url" ]] || die "install requires a URL (GitHub repo or direct AppImage link)"
	shift || true

	# Parse optional flags
	local pattern=""
	local app_id_override=""
	while [[ $# -gt 0 ]]; do
		case "$1" in
		--pattern)
			pattern="$2"
			shift 2
			;;
		--name)
			app_id_override="$2"
			shift 2
			;;
		*)
			die "Unknown option: $1"
			;;
		esac
	done

	# Detect if GitHub URL or direct download link
	local is_github=false
	local owner_repo=""
	local asset_name=""
	local version=""
	local download_url=""

	if [[ "$url" =~ ^https?://github\.com/ ]]; then
		is_github=true
		owner_repo=$(_parse_github_url "$url")

		info "Fetching latest release for $owner_repo..."

		# Determine pattern: use --pattern if provided, otherwise default to current arch
		if [[ -z "$pattern" ]]; then
			pattern="$(uname -m).AppImage"
		fi

		# Get best asset
		asset_name=$(_github_latest "$owner_repo" "$pattern")
		download_url=$(_github_download_url "$owner_repo" "$asset_name")

		# Extract version from asset name (simple heuristic: first version-like string)
		version=$(echo "$asset_name" | sed -E 's/.*[-_]([0-9]+\.[0-9]+[^-]*).*/\1/' | head -c 20)
	else
		# Direct URL download
		info "Preparing direct download: $url"
		download_url="$url"

		# Extract filename from URL
		asset_name=$(basename "$url" | sed 's/\?.*//') # Remove query params

		# Extract app-id from filename
		version="" # Direct downloads don't have version info
	fi

	# Extract app-id from asset name (or use override)
	local app_id
	if [[ -n "$app_id_override" ]]; then
		app_id="$app_id_override"
	else
		app_id=$(_app_id "$asset_name")
	fi

	# Check idempotency (GitHub only - direct downloads always re-download)
	if [[ "$is_github" == true && -f "$STATE_DIR/${app_id}.json" ]]; then
		local existing_version
		existing_version=$(_read_state "$app_id" version)
		if [[ "$existing_version" == "$version" ]]; then
			info "AppImage already installed: ${app_id} (version $version)"
			return 0
		fi
	fi

	info "Downloading $asset_name..."

	local temp_path
	temp_path=$(mktemp)
	trap 'rm -f "$temp_path"' RETURN

	curl -f -L -o "$temp_path" "$download_url" || die "Failed to download AppImage"
	chmod +x "$temp_path"

	info "Extracting desktop and icon..."

	# Move to final location before mounting (so we can reference it in .desktop)
	local appimage_path="$BIN_DIR/$app_id"
	mv "$temp_path" "$appimage_path"

	# Mount AppImage to extract .desktop and icon
	local mount_point
	mount_point=$(mktemp -d)
	trap 'umount "$mount_point" 2>/dev/null || true; rmdir "$mount_point" 2>/dev/null || true; rm -f "$appimage_path"' RETURN

	"$appimage_path" --appimage-mount >/dev/null 2>&1 &
	local pid=$!

	# Wait for mountpoint to appear
	local timeout=10
	while ((timeout-- > 0)); do
		if mountpoint -q "$mount_point" 2>/dev/null; then
			break
		fi
		sleep 0.1
	done

	[[ -d "$mount_point" ]] || die "Failed to mount AppImage"

	# Find .desktop file
	local desktop_file
	desktop_file=$(find "$mount_point" -name "*.desktop" -type f 2>/dev/null | head -1)
	[[ -n "$desktop_file" ]] || die "No .desktop file found in AppImage"

	# Find icon (prefer from Icon= field in .desktop)
	local icon_path
	if [[ -f "$desktop_file" ]]; then
		local icon_name
		icon_name=$(grep '^Icon=' "$desktop_file" | cut -d= -f2)
		if [[ -n "$icon_name" ]]; then
			icon_path=$(find "$mount_point" -name "${icon_name}*" -type f 2>/dev/null | head -1)
		fi
	fi

	# Fallback: look for any common icon extension
	if [[ -z "$icon_path" ]]; then
		icon_path=$(find "$mount_point" -type f \( -name "*.png" -o -name "*.svg" -o -name "*.ico" \) 2>/dev/null | head -1)
	fi

	# Copy desktop file
	local desktop_dest="$DESKTOP_DIR/${app_id}.desktop"
	cp "$desktop_file" "$desktop_dest"

	# Patch Exec= in .desktop to point to AppImage
	sed -i "s|^Exec=.*|Exec=$appimage_path|" "$desktop_dest"

	# Add X-AppImage-Version
	if ! grep -q "^X-AppImage-Version=" "$desktop_dest"; then
		echo "X-AppImage-Version=$version" >>"$desktop_dest"
	fi

	# Copy icon if found
	if [[ -n "$icon_path" ]]; then
		local icon_ext="${icon_path##*.}"
		local icon_size

		# Try to extract size from path (common pattern: 256x256, 128, etc.)
		icon_size=$(basename "$(dirname "$icon_path")" | sed -E 's/^([0-9]+)x?[0-9]*$/\1/; t; d')
		icon_size="${icon_size:-256}"

		local icon_dest="$ICON_DIR/${icon_size}x${icon_size}/apps/${app_id}.${icon_ext}"
		mkdir -p "$(dirname "$icon_dest")"
		cp "$icon_path" "$icon_dest"
	fi

	# Write state (use URL for direct downloads, repo for GitHub)
	local state_repo="${owner_repo:-$download_url}"
	local state_pattern="$pattern"
	_write_state "$app_id" "$state_repo" "$state_pattern" "$version"

	# Unmount
	kill $pid 2>/dev/null || true
	wait $pid 2>/dev/null || true

	# Clear RETURN trap (success path)
	trap - RETURN

	info "Installed: $app_id (version $version)"
	info "Run with: $app_id"
}

# ============================================================================
# Command: update
# ============================================================================

cmd_update() {
	local app_id="${1:-}"
	shift || true

	# If app_id provided, update only that one; otherwise update all
	local app_ids
	if [[ -n "$app_id" ]]; then
		app_ids=("$app_id")
	else
		mapfile -t app_ids < <(find "$STATE_DIR" -maxdepth 1 -name "*.json" -type f -printf '%f\n' | sed 's/\.json$//')
	fi

	[[ ${#app_ids[@]} -eq 0 ]] && {
		info "No AppImages to update"
		return 0
	}

	for id in "${app_ids[@]}"; do
		_update_one "$id"
	done
}

_update_one() {
	local app_id=$1

	local repo
	repo=$(_read_state "$app_id" repo) || die "Cannot read metadata for $app_id"

	local pattern
	pattern=$(_read_state "$app_id" pattern)

	local current_version
	current_version=$(_read_state "$app_id" version)

	local appimage_path="$BIN_DIR/$app_id"

	[[ -f "$appimage_path" ]] || die "AppImage not found: $appimage_path"

	info "Checking updates for $app_id..."

	# Try delta update first if appimageupdatetool is available
	if command -v appimageupdatetool &>/dev/null; then
		info "Using delta update (appimageupdatetool)..."
		if appimageupdatetool "$appimage_path" >/dev/null 2>&1; then
			# Re-query GitHub to get the new version
			local latest_asset
			latest_asset=$(_github_latest "$repo" "$pattern")
			local new_version
			new_version=$(echo "$latest_asset" | sed -E 's/.*[-_]([0-9]+\.[0-9]+[^-]*).*/\1/')
			_write_state "$app_id" "$repo" "$pattern" "$new_version"
			info "Updated $app_id to $new_version"
			return 0
		fi
	fi

	# Fallback: GitHub
	info "Checking GitHub for updates..."

	local latest_asset
	latest_asset=$(_github_latest "$repo" "$pattern")

	local latest_version
	latest_version=$(echo "$latest_asset" | sed -E 's/.*[-_]([0-9]+\.[0-9]+[^-]*).*/\1/')

	if [[ "$latest_version" == "$current_version" ]]; then
		info "Already up-to-date: $app_id (version $current_version)"
		return 0
	fi

	info "Updating $app_id from $current_version to $latest_version..."

	local download_url
	download_url=$(_github_download_url "$repo" "$latest_asset")

	# Download to temp, then replace
	local temp_path
	temp_path=$(mktemp)
	trap 'rm -f "$temp_path"' RETURN

	curl -f -L -o "$temp_path" "$download_url" || die "Failed to download update"
	chmod +x "$temp_path"

	# Replace binary (no need to rm first)
	mv "$temp_path" "$appimage_path"

	# Update desktop entry Exec= and version
	local desktop_file="$DESKTOP_DIR/${app_id}.desktop"
	if [[ -f "$desktop_file" ]]; then
		sed -i "s|^Exec=.*|Exec=$appimage_path|" "$desktop_file"
		sed -i "s/^X-AppImage-Version=.*/X-AppImage-Version=$latest_version/" "$desktop_file"
	fi

	# Update state
	_write_state "$app_id" "$repo" "$pattern" "$latest_version"

	info "Updated: $app_id (version $latest_version)"
}

# ============================================================================
# Command: remove
# ============================================================================

cmd_remove() {
	local app_id="${1:-}"
	[[ -n "$app_id" ]] || die "remove requires an app-id"
	shift || true

	[[ -f "$STATE_DIR/${app_id}.json" ]] || die "Unknown app-id: $app_id"

	if [[ "$NONINTERACTIVE" != true ]]; then
		echo -n "Remove $app_id? [y/N] "
		read -r confirm
		[[ "$confirm" == "y" || "$confirm" == "Y" ]] || return 0
	fi

	local appimage_path="$BIN_DIR/$app_id"

	if [[ -f "$appimage_path" ]]; then
		rm "$appimage_path"
		info "Removed AppImage"
	fi

	rm -f "$STATE_DIR/${app_id}.json"
	rm -f "$DESKTOP_DIR/${app_id}.desktop"

	# Remove icon (any size/extension)
	find "$ICON_DIR" -path "*/${app_id}.*" -type f -delete 2>/dev/null || true

	info "Removed: $app_id"
}

# ============================================================================
# Command: list
# ============================================================================

cmd_list() {
	[[ -d "$STATE_DIR" ]] || return 0

	local count=0
	printf "%-20s %-10s %s\n" "APP-ID" "VERSION" "REPO"
	printf "%-20s %-10s %s\n" "------" "-------" "----"

	for state_file in "$STATE_DIR"/*.json; do
		[[ -f "$state_file" ]] || continue

		local app_id
		app_id=$(basename "$state_file" .json)

		local version
		version=$(jq -r '.version' "$state_file" 2>/dev/null) || continue

		local repo
		repo=$(jq -r '.repo' "$state_file" 2>/dev/null) || continue

		printf "%-20s %-10s %s\n" "$app_id" "$version" "$repo"
		((count++))
	done

	[[ $count -eq 0 ]] && echo "(no apps installed)"
}

# ============================================================================
# Main
# ============================================================================

main() {
	# Check dependencies
	for cmd in curl jq; do
		command -v "$cmd" &>/dev/null || die "Required command not found: $cmd"
	done

	local command=${1:-help}
	shift || true

	case "$command" in
	install)
		cmd_install "$@"
		;;
	update)
		cmd_update "$@"
		;;
	remove)
		cmd_remove "$@"
		;;
	list)
		cmd_list "$@"
		;;
	--noninteractive)
		NONINTERACTIVE=true
		main "${@}"
		;;
	help | -h | --help)
		cat <<-EOF
			usage: appiget [--noninteractive] <command> [args]

			commands:
			  install <url> [--pattern <pattern>] [--name <app-id>]
			                              Install AppImage from GitHub release or direct URL
			  update [app-id]             Update app (or all if no app-id)
			  remove <app-id>             Remove installed AppImage
			  list                        List installed AppImages

			options:
			  --noninteractive            Suppress prompts and progress output
			  --pattern <pattern>         Asset pattern for GitHub releases (e.g., x86_64.AppImage)
			                              Default: current architecture
			  --name <app-id>             Override app-id for binary name and state tracking
			                              Default: auto-derived from filename

			examples:
			  appiget install https://github.com/pingdotgg/t3code
			  appiget install AppImageCommunity/AppImageUpdate --pattern appimageupdatetool-x86_64.AppImage
			  appiget install AppImageCommunity/AppImageUpdate --pattern appimageupdatetool-x86_64.AppImage --name appimageupdatetool
			  appiget list
			  appiget update t3code
			  appiget remove t3code --noninteractive
		EOF
		;;
	*)
		die "Unknown command: $command. Use 'appiget help' for usage."
		;;
	esac
}

main "$@"
